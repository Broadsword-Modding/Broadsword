{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "broadsword",
  "version": "2.0.0",
  "description": "Next-generation modding framework for Half Sword (UE5) using modern C++26",
  "homepage": "https://github.com/Broadsword-Modding/Broadsword",
  "license": "MIT",
  "dependencies": [
    {
      "name": "imgui",
      "features": [
        "dx11-binding",
        "dx12-binding",
        "win32-binding"
      ]
    },
    "minhook",
    "nlohmann-json",
    "glm",
    "toml11"
  ],
  "builtin-baseline": "latest",
  "overrides": [],
  "features": {
    "tests": {
      "description": "Build unit and integration tests",
      "dependencies": [
        "catch2"
      ]
    },
    "examples": {
      "description": "Build example mods"
    }
  }
}
